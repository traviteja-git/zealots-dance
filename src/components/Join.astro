<!-- BOOK US -->
<section class="section book" id="book">
  <div class="container">
    <div class="section-tag">Book Us</div>
    <h2 class="section-title">Got an event?<br />We've got the floor.</h2>
    <p class="section-sub"> Sangeet Night,Corporate events, flash mobs — if there's a stage and a crowd, we're in. Fill the form below or reach out directly.</p>
    <div class="book-grid">
      <div class="book-card">
        <div class="book-icon">🏢</div>
        <h3>Corporate Events</h3>
        <p>We know the culture — and we know how to own it.</p>
      </div>
      <div class="book-card">
        <div class="book-icon">💃🕺</div>
        <h3>Sangeet & Weddings</h3>
        <p>Unforgettable sangeet and reception performances.</p>
      </div>
      <div class="book-card">
        <div class="book-icon">⚡</div>
        <h3>Flash Mobs</h3>
        <p>Surprise your crowd with something they'll never forget.</p>
      </div>
    </div>

    <!-- Enquiry Form -->
    <div class="book-form-wrap">
      <div class="book-form-header">
        <h3 class="book-form-title">Send an Enquiry</h3>
        <p class="book-form-sub">We'll reply to your email within 24 hours.</p>
      </div>

      <!-- ✅ SUCCESS STATE -->
      <div class="form-success" id="form-success" style="display:none">
        <div class="form-success-icon">✅</div>
        <h4>Enquiry sent!</h4>
        <p>Thanks! We've received your message and will get back to you within 24 hours.</p>
      </div>

      <!-- 🔁 Replace YOUR_FORM_ID with your Formspree form ID -->
      <!-- Sign up free at https://formspree.io → New Form → copy the ID from the endpoint URL -->
      <form class="book-form" id="book-form">
        <!-- Honeypot field — hidden from real users, catches bots -->
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />

        <div class="form-row">
          <div class="form-group">
            <label for="booking-name">Your Name *</label>
            <input type="text" id="booking-name" name="name" placeholder="Your Name" required />
          </div>
          <div class="form-group">
            <label for="booking-email">Email Address *</label>
            <input type="email" id="booking-email" name="email" placeholder="you@example.com" required />
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="booking-phone">Phone Number</label>
            <input type="tel" id="booking-phone" name="phone" placeholder="Your Mobile Number" />
          </div>
          <div class="form-group">
            <label for="booking-event">Event Type *</label>
            <select id="booking-event" name="event" required>
              <option value="" disabled selected>Select event type</option>
              <option value="Corporate Event">Corporate Event</option>
              <option value="Sangeet / Wedding">Sangeet / Wedding</option>
              <option value="Flash Mob">Flash Mob</option>
              <option value="Other">Other</option>
            </select>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="booking-date">Event Date</label>
            <input type="date" id="booking-date" name="date" />
          </div>
          <div class="form-group">
            <label for="booking-city">City / Venue</label>
            <input type="text" id="booking-city" name="city" placeholder="e.g. Hyderabad" />
          </div>
        </div>
        <div class="form-group">
          <label for="booking-message">Additional Details</label>
          <textarea id="booking-message" name="message" rows="3" placeholder="Tell us about expected guests, performance duration, etc."></textarea>
        </div>

        <div id="form-error" class="form-error-msg" style="display:none">
          Something went wrong. Please try again or reach out via WhatsApp.
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary" id="form-submit">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
            <span id="form-btn-text">Send Enquiry</span>
          </button>
          <a href="https://wa.me/919542710096?text=Hi%20Zealots%2C%20I%20want%20to%20book%20you%20for%20an%20event!" target="_blank" rel="noopener" class="btn btn-whatsapp">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
        </div>
        <p class="book-form-contact">Or email us at <a href="mailto:zealotsdancecrew@gmail.com">zealotsdancecrew@gmail.com</a></p>
      </form>
    </div>
  </div>
</section>

<script>
  const FORMSPREE_ID = 'mlgojddy'; // Formspree form ID

  const form = document.getElementById('book-form') as HTMLFormElement;
  const submitBtn = document.getElementById('form-submit') as HTMLButtonElement;
  const btnText = document.getElementById('form-btn-text') as HTMLSpanElement;
  const successEl = document.getElementById('form-success') as HTMLElement;
  const errorEl = document.getElementById('form-error') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Show loading state
    submitBtn.disabled = true;
    btnText.textContent = 'Sending…';
    errorEl.style.display = 'none';

    try {
      const res = await fetch(`https://formspree.io/f/${FORMSPREE_ID}`, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        form.style.display = 'none';
        successEl.style.display = 'flex';
      } else {
        throw new Error('Formspree error');
      }
    } catch {
      errorEl.style.display = 'block';
      submitBtn.disabled = false;
      btnText.textContent = 'Send Enquiry';
    }
  });
</script>
