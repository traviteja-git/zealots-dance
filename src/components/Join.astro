---
const base = import.meta.env.BASE_URL;
---
<section class="section join" id="join">
  <div class="container">
    <div class="join-inner">
      <div class="join-logo-wrap">
        <img src={`${base}/logo.png`} alt="Zealots Dance Crew" class="join-logo-img" />
      </div>
      <div class="join-content">
        <div class="tag-dark">Join the Crew</div>
        <h2 class="section-title join-title">Are you a corporate<br />dancer too?</h2>
        <p class="section-sub join-sub">If you punch in at 9 and still find yourself counting beats at your desk — you belong here. Reach out and join a crew that gets it.</p>
        <div class="join-actions">
          <a href="https://www.instagram.com/zealots_dance" target="_blank" rel="noopener" class="btn btn-join-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            DM us on Instagram
          </a>
          <a href="https://youtube.com/@zealotsdancecrew" target="_blank" rel="noopener" class="btn btn-join-outline">
            Watch Our Story
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- BOOK US -->
<section class="section book" id="book">
  <div class="container">
    <div class="section-tag">Book Us</div>
    <h2 class="section-title">Got an event?<br />We've got the floor.</h2>
    <p class="section-sub"> Sangeet Night,Corporate events, flash mobs — if there's a stage and a crowd, we're in. Fill the form below or reach out directly.</p>
    <div class="book-grid">
      <div class="book-card">
        <div class="book-icon">🏢</div>
        <h3>Corporate Events</h3>
        <p>We know the culture — and we know how to own it.</p>
      </div>
      <div class="book-card">
        <div class="book-icon">💃🕺</div>
        <h3>Sangeet & Weddings</h3>
        <p>Unforgettable sangeet and reception performances.</p>
      </div>
      <div class="book-card">
        <div class="book-icon">⚡</div>
        <h3>Flash Mobs</h3>
        <p>Surprise your crowd with something they'll never forget.</p>
      </div>
    </div>

    <!-- Enquiry Form -->
    <div class="book-form-wrap">
      <div class="book-form-header">
        <h3 class="book-form-title">Send an Enquiry</h3>
        <p class="book-form-sub">We'll get back to you within 24 hours.</p>
      </div>
      <form class="book-form" id="book-form">
        <div class="form-row">
          <div class="form-group">
            <label for="booking-name">Your Name *</label>
            <input type="text" id="booking-name" name="name" placeholder="Your Name" required />
          </div>
          <div class="form-group">
            <label for="booking-phone">Phone Number *</label>
            <input type="tel" id="booking-phone" name="phone" placeholder="Your Mobile Number" required />
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="booking-event">Event Type *</label>
            <select id="booking-event" name="event" required>
              <option value="" disabled selected>Select event type</option>
              <option value="Corporate Event">Corporate Event</option>
              <option value="Sangeet / Wedding">Sangeet / Wedding</option>
              <option value="Flash Mob">Flash Mob</option>
              <option value="Other">Other</option>
            </select>
          </div>
          <div class="form-group">
            <label for="booking-date">Event Date</label>
            <input type="date" id="booking-date" name="date" />
          </div>
        </div>
        <div class="form-group">
          <label for="booking-message">Additional Details</label>
          <textarea id="booking-message" name="message" rows="3" placeholder="Tell us about the venue, expected guests, performance duration, etc."></textarea>
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-whatsapp" id="form-submit">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Send via WhatsApp
          </button>
          <a href="https://www.instagram.com/zealots_dance" target="_blank" rel="noopener" class="btn btn-outline">
            DM on Instagram
          </a>
          <a href="mailto:zealotsdancecrew@gmail.com" class="btn btn-outline">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
            Email Us
          </a>
        </div>
        <p class="book-form-contact">Or email us directly at <a href="mailto:zealotsdancecrew@gmail.com">zealotsdancecrew@gmail.com</a></p>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('book-form') as HTMLFormElement;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const name = data.get('name') as string;
    const phone = data.get('phone') as string;
    const event = data.get('event') as string;
    const date = data.get('date') as string;
    const message = data.get('message') as string;

    const text = [
      `Hi Zealots! I'd like to book you for an event.`,
      ``,
      `*Name:* ${name}`,
      `*Phone:* ${phone}`,
      `*Event Type:* ${event}`,
      date ? `*Event Date:* ${date}` : null,
      message ? `*Details:* ${message}` : null,
    ].filter(Boolean).join('\n');

    const url = `https://wa.me/919542710096?text=${encodeURIComponent(text)}`;
    window.open(url, '_blank');
  });
</script>
