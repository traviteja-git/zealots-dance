<section class="section join" id="join">
  <div class="container">
    <div class="join-inner">
      <div class="join-logo-wrap">
        <img src="/logo.png" alt="Zealots Dance Crew" class="join-logo-img" />
      </div>
      <div class="join-content">
        <div class="tag-dark">Join the Crew</div>
        <h2 class="section-title join-title">Are you a corporate<br />dancer too?</h2>
        <p class="section-sub join-sub">If you punch in at 9 and still find yourself counting beats at your desk — you belong here. Find out what it takes and reach out when you're ready.</p>
        <div class="join-actions">
          <a href="/join" class="btn btn-join-primary">
            How to Join
          </a>
          <a href="https://www.youtube.com/@ZealotsDanceCrew" target="_blank" rel="noopener" class="btn btn-join-outline">
            Watch Our Story
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
