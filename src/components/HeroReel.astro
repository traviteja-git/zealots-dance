---
// Flash mob video — high-energy, best first impression
const reelVideoId = 'vMTCqRnVCQo';
---
<section class="hero-reel" id="reel">
  <div class="hero-reel-inner">
    <div class="hero-reel-label">
      <div class="section-tag">Watch Us Move</div>
      <p class="hero-reel-sub">A flash mob that stopped a crowd — and started a movement.</p>
    </div>
    <div class="hero-reel-embed">
      <div class="video-wrapper">
        <iframe
          src={`https://www.youtube.com/embed/${reelVideoId}?rel=0&modestbranding=1`}
          title="Zealots Dance Crew — Flash Mob"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
    </div>
    <div class="hero-reel-cta">
      <a href="https://www.youtube.com/@ZealotsDanceCrew" target="_blank" rel="noopener" class="btn btn-outline">
        See All Performances
      </a>
    </div>
  </div>
</section>

<style>
  .hero-reel {
    background: #000;
    padding: 3rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .hero-reel-inner {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
  }

  .hero-reel-label {
    text-align: center;
  }

  .hero-reel-sub {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.55);
    margin-top: 0.5rem;
  }

  .hero-reel-embed {
    width: 100%;
  }

  .video-wrapper {
    position: relative;
    padding-bottom: 56.25%; /* 16:9 */
    height: 0;
    overflow: hidden;
    border-radius: 12px;
    background: #111;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.6);
  }

  .video-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
    border-radius: 12px;
  }

  .hero-reel-cta {
    margin-top: 0.25rem;
  }

  @media (max-width: 640px) {
    .hero-reel {
      padding: 3rem 0 2.5rem;
    }
    .hero-reel-sub {
      font-size: 0.9rem;
    }
  }
</style>
