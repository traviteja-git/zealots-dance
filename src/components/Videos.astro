---
import { featuredVideos } from '../data/videos';
const hasRealIds = featuredVideos.some(v => !v.id.startsWith('YOUR_'));
---
<section class="section videos" id="videos">
  <div class="container">
    <div class="section-tag">Watch</div>
    <h2 class="section-title">Our Latest Moves</h2>
    <p class="section-sub">Performances, battles, and behind-the-scenes — straight from the floor.</p>

    {hasRealIds ? (
      <div class="video-grid">
        {featuredVideos.map((video) => (
          <div class="video-embed">
            <iframe
              src={`https://www.youtube.com/embed/${video.id}`}
              title={video.title}
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
        ))}
      </div>
    ) : (
      <div class="video-placeholder-grid">
        <div class="video-placeholder">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/></svg>
          <span>Add Video ID 1</span>
          <p>Edit src/data/videos.ts</p>
        </div>
        <div class="video-placeholder">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/></svg>
          <span>Add Video ID 2</span>
          <p>Edit src/data/videos.ts</p>
        </div>
        <div class="video-placeholder">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/></svg>
          <span>Add Video ID 3</span>
          <p>Edit src/data/videos.ts</p>
        </div>
      </div>
    )}

    <div class="video-cta">
      <a href="https://youtube.com/@zealotsdancecrew" target="_blank" rel="noopener" class="btn btn-primary">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/></svg>
        See All Videos on YouTube
      </a>
    </div>
  </div>
</section>
