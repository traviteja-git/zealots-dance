---
import { featuredVideos } from '../data/videos';

interface Props {
  featured?: boolean;
}
const { featured = false } = Astro.props;
const videos = featured ? featuredVideos.slice(0, 3) : featuredVideos;
const hasRealIds = videos.some(v => !v.id.startsWith('YOUR_'));
---
<section class="section videos" id="videos">
  <div class="container">
    <div class="section-tag">Watch</div>
    <h2 class="section-title">Our Latest Moves</h2>
    <p class="section-sub">Performances, battles, and behind-the-scenes — straight from the floor.</p>

    {hasRealIds ? (
      <div class="vc">
        <div class="vc-viewport">
          {videos.map((video, i) => (
            <div class={`vc-slide${i === 0 ? ' active' : ''}`}>
              <div class="video-embed">
                <iframe
                  src={`https://www.youtube.com/embed/${video.id}?enablejsapi=1`}
                  title={video.title}
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  loading="lazy"
                ></iframe>
              </div>
            </div>
          ))}
        </div>

        <div class="vc-controls">
          <button class="vc-btn vc-prev" aria-label="Previous video">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><polyline points="15 18 9 12 15 6"/></svg>
          </button>

          <div class="vc-dots">
            {videos.map((_, i) => (
              <button class={`vc-dot${i === 0 ? ' active' : ''}`} data-dot={i} aria-label={`Video ${i + 1}`}></button>
            ))}
          </div>

          <button class="vc-btn vc-next" aria-label="Next video">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
      </div>
    ) : (
      <div class="video-placeholder-grid">
        {[1,2,3].map(n => (
          <div class="video-placeholder">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/></svg>
            <span>Add Video ID {n}</span>
            <p>Edit src/data/videos.ts</p>
          </div>
        ))}
      </div>
    )}

    <div class="video-cta">
      <a href="https://www.youtube.com/@ZealotsDanceCrew" target="_blank" rel="noopener" class="btn btn-primary">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/></svg>
        See All Videos on YouTube
      </a>
    </div>
  </div>
</section>

<script>
  const slides = Array.from(document.querySelectorAll<HTMLElement>('.vc-slide'));
  const dots   = Array.from(document.querySelectorAll<HTMLElement>('.vc-dot'));
  const prev   = document.querySelector<HTMLButtonElement>('.vc-prev');
  const next   = document.querySelector<HTMLButtonElement>('.vc-next');
  let cur = 0;

  function pauseCurrent() {
    const iframe = slides[cur].querySelector<HTMLIFrameElement>('iframe');
    iframe?.contentWindow?.postMessage('{"event":"command","func":"pauseVideo","args":""}', '*');
  }

  function goTo(n: number) {
    pauseCurrent();
    slides[cur].classList.remove('active');
    dots[cur].classList.remove('active');
    cur = (n + slides.length) % slides.length;
    slides[cur].classList.add('active');
    dots[cur].classList.add('active');
  }

  prev?.addEventListener('click', () => goTo(cur - 1));
  next?.addEventListener('click', () => goTo(cur + 1));
  dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

  // Swipe
  let tx = 0;
  const vp = document.querySelector<HTMLElement>('.vc-viewport');
  vp?.addEventListener('touchstart', e => { tx = e.touches[0].clientX; }, { passive: true });
  vp?.addEventListener('touchend', e => {
    const diff = tx - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) goTo(cur + (diff > 0 ? 1 : -1));
  });
</script>
