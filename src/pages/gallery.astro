---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Gallery from '../components/Gallery.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout
  title="Gallery | Zealots Dance Crew"
  description="Photo gallery of Zealots Dance Crew — corporate events, sangeet performances, workshops, and crew outings in Hyderabad."
>
  <Nav />
  <main class="page-content">
    <section class="page-hero">
      <div class="container">
        <div class="section-tag">Gallery</div>
        <h1 class="section-title page-hero-title">Moments from<br />the floor.</h1>
        <p class="section-sub page-hero-sub">Every corporate event, sangeet night, flash mob, and crew outing — captured.</p>
      </div>
    </section>
    <Gallery />
  </main>
  <Footer />
</BaseLayout>
