---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Page Not Found | Zealots Dance Crew"
  description="The page you're looking for doesn't exist. Head back to the Zealots Dance Crew homepage."
>
  <main class="not-found">
    <div class="not-found-inner">
      <div class="not-found-tag">404</div>
      <h1 class="not-found-title">Wrong stage.</h1>
      <p class="not-found-sub">This page doesn't exist — but the crew is very much alive.<br />Head back and find what you're looking for.</p>
      <a href="/" class="btn btn-primary">Back to Home</a>
    </div>
  </main>
</BaseLayout>

<style>
  .not-found {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg);
    text-align: center;
    padding: 2rem;
  }

  .not-found-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .not-found-tag {
    font-family: var(--font-display);
    font-size: clamp(6rem, 20vw, 12rem);
    line-height: 1;
    color: var(--red);
    letter-spacing: 0.05em;
  }

  .not-found-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 4rem);
    color: var(--fg);
    letter-spacing: 0.03em;
  }

  .not-found-sub {
    font-size: 1.05rem;
    color: var(--fg-muted);
    max-width: 420px;
    line-height: 1.7;
  }
</style>
