---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout
  title="Join the Crew | Zealots Dance Crew"
  description="Want to join Zealots Dance Crew in Hyderabad? Learn what we look for, how to reach out, and what life in the crew actually looks like."
>
  <Nav />
  <main class="page-content">

    <!-- Hero -->
    <section class="about-hero join-page-hero">
      <div class="container">
        <div class="section-tag">Join the Crew</div>
        <h1 class="section-title about-hero-title">Still counting beats<br />at your desk?</h1>
        <p class="section-sub about-hero-sub">You hold down a 9-to-5. You still feel the music. That's enough to belong here — no experience required.</p>
        <div class="about-hero-actions">
          <a href="https://www.instagram.com/zealots_dance" target="_blank" rel="noopener" class="btn btn-primary">DM us on Instagram</a>
          <a href="/crew" class="btn btn-outline">Meet the Crew</a>
        </div>
      </div>
    </section>

    <!-- Quick facts -->
    <section class="section join-facts-section">
      <div class="container">
        <div class="styles-grid">
          <div class="style-card">
            <div class="style-num">🆓</div>
            <h3 class="style-name">Free to join</h3>
            <p class="style-desc">No membership fees, no joining charges. Zealots is entirely self-funded and community-run.</p>
          </div>
          <div class="style-card">
            <div class="style-num">📍</div>
            <h3 class="style-name">Hyderabad only</h3>
            <p class="style-desc">Rehearsals and all performances happen within Hyderabad. You need to be based here.</p>
          </div>
          <div class="style-card">
            <div class="style-num">🕐</div>
            <h3 class="style-name">1–2× a week</h3>
            <p class="style-desc">Weekly rehearsal sessions — evenings or weekends, typically 1.5 to 2 hours each.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Life in Zealots -->
    <section class="section join-life-section">
      <div class="container">
        <div class="join-life-grid">
          <div class="join-life-photos">
            <img src="/Zealots/Corporate Events/zealots_corporate_24.jpeg" alt="Zealots Dance Crew" class="join-life-img" />
          </div>
          <div class="join-life-content">
            <div class="section-tag">Life in Zealots</div>
            <h2 class="section-title join-life-title">Real people.<br />Real moves.</h2>
            <p class="section-sub join-life-desc">We're not a performance academy. We're corporate professionals who show up every week because the floor is the best part of the day. New friendships, shared stages, and a space where nobody judges how long it's been since you last danced.</p>
            <ul class="join-perks-list">
              <li>Perform at real events — corporate days, sangeet nights, flash mobs</li>
              <li>Build genuine friendships outside the office</li>
              <li>Learn Bollywood, Hip-Hop &amp; Contemporary from scratch</li>
              <li>The best stress relief after a long day at work</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- How to join -->
    <section class="section join-process-section">
      <div class="container">
        <div class="section-tag">How It Works</div>
        <h2 class="section-title">Three steps<br />to the floor.</h2>
        <p class="section-sub">No auditions. No pressure. Just show up.</p>
        <div class="styles-grid join-steps-grid">
          <div class="style-card">
            <div class="style-num">01</div>
            <h3 class="style-name">DM us on Instagram</h3>
            <p class="style-desc">Send a message to <a href="https://www.instagram.com/zealots_dance" target="_blank" rel="noopener" class="join-link">@zealots_dance</a>. Tell us your name, what you do, and why you want to join. Dance background optional.</p>
          </div>
          <div class="style-card">
            <div class="style-num">02</div>
            <h3 class="style-name">Chat with a captain</h3>
            <p class="style-desc">One of our founders will have a short call with you. No audition, no judgment — just a conversation to see if it's the right fit.</p>
          </div>
          <div class="style-card">
            <div class="style-num">03</div>
            <h3 class="style-name">Join a rehearsal</h3>
            <p class="style-desc">Come to a practice session. Move, meet the crew, feel the energy. If it clicks, you're in.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section join-faq-section">
      <div class="container">
        <div class="section-tag">FAQ</div>
        <h2 class="section-title join-faq-title">Common questions.</h2>
        <div class="join-faqs">
          <details class="join-faq">
            <summary>I haven't danced in years — is that okay?</summary>
            <p>Absolutely. Most of our members aren't trained dancers. They're professionals who love to move. We build from wherever you are.</p>
          </details>
          <details class="join-faq">
            <summary>Do I need to be based in Hyderabad?</summary>
            <p>Yes. All rehearsals and performances happen within Hyderabad only.</p>
          </details>
          <details class="join-faq">
            <summary>Will I have to perform at events right away?</summary>
            <p>No. You'll rehearse and find your footing first. We only put people on stage when they feel genuinely ready — no pressure.</p>
          </details>
          <details class="join-faq">
            <summary>Is this only for people from one company?</summary>
            <p>Not at all. Since 2021, Zealots has been open to professionals from any company or industry. The crew spans multiple organisations across Hyderabad.</p>
          </details>
          <details class="join-faq">
            <summary>Is there a cost to join?</summary>
            <p>None. No membership fees, no joining charges — Zealots is entirely community-run.</p>
          </details>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section about-cta">
      <div class="container">
        <div class="about-cta-inner">
          <h2 class="section-title about-cta-title">Ready to move<br />with us?</h2>
          <p class="section-sub about-cta-sub">Drop us a DM and let's get you on the floor.</p>
          <div class="about-cta-actions">
            <a href="https://www.instagram.com/zealots_dance" target="_blank" rel="noopener" class="btn btn-primary">DM us on Instagram</a>
            <a href="/crew" class="btn btn-outline">Meet the Crew</a>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</BaseLayout>

<style>
  /* Life section */
  .join-life-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
    align-items: center;
  }

  .join-life-photos {
    height: 420px;
    border-radius: 8px;
    overflow: hidden;
  }

  .join-life-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .join-life-desc {
    margin-bottom: 1.5rem;
  }

  .join-perks-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .join-perks-list li {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.7);
    padding-left: 1.25rem;
    position: relative;
    line-height: 1.5;
  }

  .join-perks-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: #e63946;
  }

  /* Process */
  .join-steps-grid .style-card a.join-link {
    color: #e63946;
    text-decoration: none;
  }

  /* FAQ */
  .join-faq-title {
    margin-bottom: 2rem;
  }

  .join-faqs {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-width: 720px;
  }

  .join-faq {
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    overflow: hidden;
  }

  .join-faq summary {
    padding: 1rem 1.25rem;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 600;
    color: rgba(255,255,255,0.85);
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    user-select: none;
    gap: 1rem;
  }

  .join-faq summary::-webkit-details-marker { display: none; }

  .join-faq summary::after {
    content: '+';
    font-size: 1.1rem;
    color: #e63946;
    flex-shrink: 0;
  }

  .join-faq[open] summary::after { content: '−'; }

  .join-faq[open] { border-color: rgba(230,57,70,0.3); }

  .join-faq p {
    padding: 0.75rem 1.25rem 1rem;
    font-size: 0.875rem;
    color: var(--fg-muted);
    line-height: 1.65;
    margin: 0;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  /* Responsive */
  @media (max-width: 860px) {
    .join-life-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .join-life-photos {
      height: 280px;
    }
  }
</style>
