---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import BookSection from '../components/BookSection.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout
  title="Book Us | Zealots Dance Crew"
  description="Book Zealots Dance Crew for your corporate event, sangeet night, flash mob, or private event in Hyderabad. Send an enquiry or reach us on WhatsApp."
>
  <Nav />
  <main class="page-content">
    <section class="page-hero">
      <div class="container">
        <div class="section-tag">Book Us</div>
        <h1 class="section-title page-hero-title">Let's make your<br />event unforgettable.</h1>
        <p class="section-sub page-hero-sub">Corporate days, sangeet nights, flash mobs — fill the form below or reach out directly.</p>
      </div>
    </section>
    <BookSection />
  </main>
  <Footer />
</BaseLayout>
