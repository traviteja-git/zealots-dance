---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Crew from '../components/Crew.astro';
import JoinSection from '../components/JoinSection.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout
  title="The Crew | Zealots Dance Crew"
  description="Meet the Zealots Dance Crew — the corporate professionals behind the moves. Our founders, choreographers, core members, and the alumni who built it all."
>
  <Nav />
  <main class="page-content">
    <section class="crew-hero">
      <div class="container">
        <div class="section-tag">The Crew</div>
        <h1 class="section-title crew-hero-title">Meet the people<br />behind every move.</h1>
        <p class="section-sub crew-hero-sub">Corporate professionals by day. The heart of Zealots by night. These are the faces that keep the crew alive.</p>
      </div>
    </section>
    <Crew />
    <JoinSection />
  </main>
  <Footer />
</BaseLayout>
