---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const base = import.meta.env.BASE_URL;
const {
  title = 'Zealots Dance Crew',
  description = "Zealots Dance Crew — where the dance floor meets the 9-to-5. A crew of corporate professionals who live for movement."
} = Astro.props;
const ogImage = `${base}/logo.png`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href={`${base}/logo.png`} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:image" content={`https://traviteja-git.github.io${base}/og-image.png`} />
  <meta property="og:url" content="https://traviteja-git.github.io/zealots-dance/" />

  <!-- Twitter / X Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`https://traviteja-git.github.io${base}/og-image.png`} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
  <slot />
  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll(
      '.section-tag, .tag-dark, .section-title, .section-sub, .about-text, .about-visual, .video-grid, .video-cta, .social-card, .join-logo-wrap, .join-content, .tl-item, .crew-card, .book-card'
    ).forEach(el => {
      el.classList.add('reveal');
      observer.observe(el);
    });
  </script>
</body>
</html>
